# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Upstash Redis (session caching — REST API)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Standard Redis (BullMQ job queue — TCP connection)
REDIS_URL=redis://localhost:6379

# Langfuse observability
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Internal Next.js ↔ FastAPI auth (generate a random 32-byte hex string)
PIPELINE_URL=http://localhost:8000
PIPELINE_SECRET=change-me-to-random-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
